    {
      "type": "SpdxDocument",
      "spdxId": "https://github.com/goenninger-b-t/adsp-sc598-custom#SPDXRef-DOCUMENT",
      "creationInfo": "_:creationInfo",
      "name": "adsp-sc598-custom SBOM",
      "profileConformance": [ "core", "software", "simpleLicensing" ],
      "dataLicense": "https://github.com/goenninger-b-t/adsp-sc598-custom#SPDXRef-License-CC0-1.0",
      "rootElement": [ "https://github.com/goenninger-b-t/adsp-sc598-custom#SPDXRef-SBOM" ],
      "element": [ "https://github.com/goenninger-b-t/adsp-sc598-custom#SPDXRef-SBOM" ],
      "comment": "Scope: the ADSP-SC598 Yocto build-harness repository (first-party Makefile, bin/ scripts, overlays, config, and the bundled hello-world example app) plus the external build/runtime tools it depends on. This SBOM does NOT describe the firmware/SD-card IMAGE the harness produces; that image is built from the Analog Devices Yocto BSP (poky + meta-adi, pinned via manifest release-5.0.1.xml) and carries its own, far larger SBOM that is generatable with Yocto's SPDX support (the create-spdx/create-spdx-3.0 classes). Conforms to SPDX 3.0.1; carries the NTIA SBOM minimum elements (supplier, component name, version, unique identifiers, dependency relationships, author, timestamp)."
    },

